[app]
# Interface and port where the app will run its webserver.  The default value
# of localhost will only listen to connections from the current machine. To
# listen on all interfaces use '0.0.0.0'. To listen on the default web address
# port, use port 80 (this will require running with elevated permissions).
address = "localhost:9000"

# Database.
[db]
host = "localhost"
port = 5432
user = "listmonk"
password = "listmonk"

# Ensure that this database has been created in Postgres.
database = "listmonk"

ssl_mode = "disable"
max_open = 25
max_idle = 25
max_lifetime = "300s"

# Optional space separated Postgres DSN params. eg: "application_name=listmonk gssencmode=disable"
params = ""

# Authentik proxy header authentication. When enabled, the app authenticates
# users via X-authentik-* headers injected by an Authentik outpost/reverse proxy
# sitting in front of the app. Configure via environment variables:
#   LISTMONK_security__authentik__enabled=true
#   LISTMONK_security__authentik__trusted_ips="10.0.0.0/8,127.0.0.1"
#   LISTMONK_security__authentik__trusted_secret="shared-secret"
#   LISTMONK_security__authentik__group_prefix="listmonk"
# The app must NOT be directly reachable; only the outpost/proxy should reach it.
# trusted_ips: comma-separated CIDRs/IPs of the proxy. Fail-closed if both
# trusted_ips and trusted_secret are empty. group_prefix: Authentik groups
# prefixed with this (e.g. "listmonk-admin") are mapped to app roles; users
# without a prefixed group are denied.
